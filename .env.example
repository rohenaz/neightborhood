# Neighborhood MCP Server - Environment Variables
# Copy to .env next to start.sh, or export in ~/.zshrc.
# All keys are optional — sources with missing keys are skipped gracefully.

# FBI Crime Data API (free): https://api.data.gov/signup
# FBI_API_KEY=your_key_here

# SpotCrime API: https://spotcrime.com/police/api
# SPOTCRIME_API_KEY=your_key_here

# NewsAPI: https://newsapi.org/register
# NEWSAPI_KEY=your_key_here
